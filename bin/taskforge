#!/usr/bin/env python3
"""
taskforge — длительная фоновая работа Claude Code.

N команд параллельно: Planner придумывает задачу, Executor решает,
Reviewer проверяет, при необходимости — переделывает. Качественный
корпус накапливается в ~/.claude/skills-data/taskforge/.

Команды CLI:
  taskforge wizard           interactive setup, потом start
  taskforge start [--config] запуск оркестратора (детач через nohup &)
  taskforge status           показать текущее состояние
  taskforge stop             graceful shutdown
  taskforge resume           продолжить с чекпоинтов
  taskforge --version
"""

from __future__ import annotations

import argparse
import hashlib
import json
import os
import re
import signal
import subprocess
import sys
import threading
import time
import urllib.error
import urllib.request
from datetime import datetime, timezone
from pathlib import Path

VERSION = "0.1.0"

# ─── Paths ────────────────────────────────────────────────────────────────────
HOME = Path.home()
SKILL_DIR = Path(__file__).resolve().parent.parent
DATA_DIR = HOME / ".claude" / "skills-data" / "taskforge"
CORPUS_DIR = DATA_DIR / "corpus"
STATE_DIR = DATA_DIR / "state"
LOGS_DIR = DATA_DIR / "logs"
CONFIG_PATH = DATA_DIR / "config.json"
INDEX_PATH = DATA_DIR / "index.json"
RUNTIME_PATH = STATE_DIR / "runtime.json"
PIDFILE_PATH = STATE_DIR / "orchestrator.pid"
STOP_FLAG_PATH = STATE_DIR / "stop.flag"  # cross-platform graceful stop signal
PROMPTS_DIR = SKILL_DIR / "prompts"

# OMC cache for usage data (preferred when available)
OMC_USAGE_CACHE = HOME / ".claude" / "plugins" / "oh-my-claudecode" / ".usage-cache.json"

# Anthropic OAuth API for usage when OMC unavailable
ANTHROPIC_USAGE_URL = "https://api.anthropic.com/api/oauth/usage"
KEYCHAIN_SERVICE = "Claude Code-credentials"
CREDENTIALS_FILE = HOME / ".claude" / ".credentials.json"

# Claude CLI
CLAUDE_BIN = os.environ.get("TASKFORGE_CLAUDE_BIN", "claude")
CLAUDE_TIMEOUT_SECONDS = int(os.environ.get("TASKFORGE_CLAUDE_TIMEOUT", "900"))  # 15 min/call

# Topics
TOPICS = [
    ("code-block",     "Писать код с нуля — один блок"),
    ("code-project",   "Писать с нуля небольшой проект по плану"),
    ("bug-block",      "Баг / оптимизация / синтаксис в одном блоке кода"),
    ("bug-project",    "Баг / оптимизация / синтаксис в проекте"),
    ("web-search",     "Веб-поиск релевантного / актуального ответа"),
    ("tools",          "Работа с инструментами"),
    ("planning",       "Планирование"),
    ("math-analysis",  "Математический анализ"),
    ("higher-math",    "Высшая математика"),
    ("logic",          "Логика"),
]
TOPIC_TITLES = dict(TOPICS)

VALID_MODELS = {"opus", "sonnet", "haiku"}

# ─── Utilities ────────────────────────────────────────────────────────────────

def utcnow_iso() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def parse_duration(text: str) -> int:
    """'5h' -> 18000, '30m' -> 1800, '90' -> 90 (seconds)."""
    text = text.strip().lower()
    m = re.match(r"^(\d+)\s*([hms]?)$", text)
    if not m:
        raise ValueError(f"Не понимаю длительность: {text!r}. Пример: '5h', '30m', '90s'.")
    value, unit = int(m.group(1)), m.group(2) or "s"
    return value * {"h": 3600, "m": 60, "s": 1}[unit]


def format_duration(seconds: float) -> str:
    seconds = int(seconds)
    if seconds < 0:
        return "просрочено"
    h, rem = divmod(seconds, 3600)
    m, s = divmod(rem, 60)
    if h:
        return f"{h}h {m}m"
    if m:
        return f"{m}m {s}s"
    return f"{s}s"


def slugify(text: str) -> str:
    text = re.sub(r"\s+", "-", text.strip().lower())
    text = re.sub(r"[^a-z0-9а-я\-]", "", text)
    return text[:60]


def normalize_for_hash(text: str) -> str:
    text = text.strip().lower()
    text = re.sub(r"\s+", " ", text)
    return text


def sha256_short(text: str) -> str:
    return hashlib.sha256(text.encode("utf-8")).hexdigest()[:16]


def ensure_dirs() -> None:
    for d in (DATA_DIR, CORPUS_DIR, STATE_DIR, LOGS_DIR, STATE_DIR / "teams"):
        d.mkdir(parents=True, exist_ok=True)


def read_json(path: Path, default=None):
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except (FileNotFoundError, json.JSONDecodeError):
        return default


def write_json_atomic(path: Path, data) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_suffix(path.suffix + ".tmp")
    tmp.write_text(json.dumps(data, ensure_ascii=False, indent=2), encoding="utf-8")
    os.replace(tmp, path)


def append_log(line: str) -> None:
    ensure_dirs()
    log_path = LOGS_DIR / f"run-{datetime.now().strftime('%Y-%m-%d')}.log"
    with log_path.open("a", encoding="utf-8") as f:
        f.write(f"[{utcnow_iso()}] {line}\n")


# ─── Config ───────────────────────────────────────────────────────────────────

DEFAULT_CONFIG = {
    "version": VERSION,
    "models": {"planner": "opus", "executor": "sonnet", "reviewer": "opus"},
    "team_count": 3,
    "duration_seconds": 5 * 3600,
    "session_limit_percent": 50,
    "weekly_limit_percent": 50,
    "topics": [t[0] for t in TOPICS],
    "max_revise_iterations": 2,
    "started_at": None,
}


def validate_config(cfg: dict) -> list[str]:
    errs: list[str] = []
    for role in ("planner", "executor", "reviewer"):
        m = cfg.get("models", {}).get(role)
        if m not in VALID_MODELS:
            errs.append(f"models.{role} должен быть одним из {VALID_MODELS}, получено {m!r}")
    if not isinstance(cfg.get("team_count"), int) or cfg["team_count"] < 1:
        errs.append("team_count должен быть целым >= 1")
    if not isinstance(cfg.get("duration_seconds"), int) or cfg["duration_seconds"] < 60:
        errs.append("duration_seconds должен быть >= 60")
    for k in ("session_limit_percent", "weekly_limit_percent"):
        v = cfg.get(k)
        if not isinstance(v, (int, float)) or v <= 0 or v > 100:
            errs.append(f"{k} должен быть в (0, 100]")
    valid_topics = {t[0] for t in TOPICS}
    bad = [t for t in cfg.get("topics", []) if t not in valid_topics]
    if bad:
        errs.append(f"Неизвестные темы: {bad}")
    if not cfg.get("topics"):
        errs.append("Нужна хотя бы одна тема")
    return errs


# ─── Usage tracking (Anthropic OAuth API) ─────────────────────────────────────

class UsageTracker:
    """Reads usage from OMC cache (preferred) or directly from Anthropic OAuth API."""

    def __init__(self):
        self._cache_data: dict | None = None
        self._cache_time: float = 0
        self._cache_ttl = 30  # seconds

    def get(self) -> dict | None:
        """Returns dict with five_hour_pct, weekly_pct, monthly_pct, or None on failure."""
        now = time.time()
        if self._cache_data and (now - self._cache_time) < self._cache_ttl:
            return self._cache_data

        # Try OMC cache first
        data = self._read_omc_cache()
        if data is None:
            data = self._fetch_from_api()

        if data is not None:
            self._cache_data = data
            self._cache_time = now
        return data

    @staticmethod
    def _read_omc_cache() -> dict | None:
        try:
            raw = json.loads(OMC_USAGE_CACHE.read_text(encoding="utf-8"))
            ts = raw.get("timestamp", 0) / 1000.0  # OMC uses ms
            if time.time() - ts > 60:  # OMC cache stale
                return None
            d = raw.get("data") or {}
            five = d.get("fiveHourPercent")
            week = d.get("weeklyPercent")
            month = d.get("monthlyPercent")
            if five is None and week is None:
                return None
            return {
                "five_hour_pct": float(five) if five is not None else 0.0,
                "weekly_pct": float(week) if week is not None else 0.0,
                "monthly_pct": float(month) if month is not None else 0.0,
                "source": "omc-cache",
            }
        except (FileNotFoundError, json.JSONDecodeError, OSError):
            return None

    def _fetch_from_api(self) -> dict | None:
        token = self._get_access_token()
        if not token:
            return None
        try:
            req = urllib.request.Request(
                ANTHROPIC_USAGE_URL,
                headers={
                    "Authorization": f"Bearer {token}",
                    "anthropic-beta": "oauth-2025-04-20",
                    "User-Agent": "taskforge/" + VERSION,
                },
            )
            with urllib.request.urlopen(req, timeout=10) as resp:
                payload = json.loads(resp.read())
        except (urllib.error.URLError, urllib.error.HTTPError, json.JSONDecodeError, OSError):
            return None
        five = (payload.get("five_hour") or {}).get("utilization") or 0
        week = (payload.get("seven_day") or {}).get("utilization") or 0
        month = (payload.get("monthly") or {}).get("utilization") or 0
        return {
            "five_hour_pct": float(five),
            "weekly_pct": float(week),
            "monthly_pct": float(month),
            "source": "anthropic-api",
        }

    @staticmethod
    def _get_access_token() -> str | None:
        # Keychain (macOS) first
        if sys.platform == "darwin":
            try:
                out = subprocess.check_output(
                    ["/usr/bin/security", "find-generic-password",
                     "-s", KEYCHAIN_SERVICE, "-w"],
                    stderr=subprocess.DEVNULL, timeout=3, text=True,
                ).strip()
                if out:
                    creds = json.loads(out)
                    creds = creds.get("claudeAiOauth", creds)
                    if creds.get("accessToken"):
                        return creds["accessToken"]
            except (subprocess.CalledProcessError, subprocess.TimeoutExpired,
                    json.JSONDecodeError, FileNotFoundError):
                pass
        # File fallback
        try:
            raw = json.loads(CREDENTIALS_FILE.read_text(encoding="utf-8"))
            creds = raw.get("claudeAiOauth", raw)
            return creds.get("accessToken")
        except (FileNotFoundError, json.JSONDecodeError):
            return None


# ─── Corpus store ─────────────────────────────────────────────────────────────

class CorpusStore:
    """Manages corpus directory and index. Thread-safe."""

    def __init__(self):
        self._lock = threading.Lock()
        ensure_dirs()
        if not INDEX_PATH.exists():
            write_json_atomic(INDEX_PATH, [])
        self._index: list[dict] = read_json(INDEX_PATH, default=[]) or []

    def recent_titles(self, topic: str, limit: int = 50) -> list[dict]:
        with self._lock:
            items = [r for r in self._index if r.get("topic") == topic]
            items.sort(key=lambda r: r.get("finished_at", ""), reverse=True)
            return [{"title": i.get("title", ""), "verdict": i.get("verdict", "")}
                    for i in items[:limit]]

    def has_hash(self, condition_hash: str) -> bool:
        with self._lock:
            return any(r.get("condition_hash") == condition_hash for r in self._index)

    def next_task_path(self, topic: str) -> Path:
        with self._lock:
            today = datetime.now().strftime("%Y-%m-%d")
            existing = list((CORPUS_DIR / topic).glob(f"{today}-task-*")) if (CORPUS_DIR / topic).exists() else []
            n = 1 + max(
                [int(re.search(r"task-(\d+)", p.name).group(1))
                 for p in existing if re.search(r"task-(\d+)", p.name)],
                default=0,
            )
            path = CORPUS_DIR / topic / f"{today}-task-{n:04d}"
            path.mkdir(parents=True, exist_ok=False)
            return path

    def append_index(self, record: dict) -> None:
        with self._lock:
            self._index.append(record)
            write_json_atomic(INDEX_PATH, self._index)

    def open_checkpoints(self) -> list[Path]:
        return list(CORPUS_DIR.glob("*/*/checkpoint.json"))


# ─── Claude runner ────────────────────────────────────────────────────────────

def run_claude(model: str, system_prompt: str, user_prompt: str,
               allowed_tools: str = "") -> str:
    """Calls `claude -p` with given model and prompts. Returns text output.

    Uses --system-prompt (full replacement, not append) so Planner/Executor/Reviewer
    are not mixed with Claude Code's default system prompt.
    Uses --tools "" to disable all tools by default — agents return pure text.
    """
    cmd = [
        CLAUDE_BIN, "-p",
        "--model", model,
        "--system-prompt", system_prompt,
        "--tools", allowed_tools,
        "--no-session-persistence",
    ]
    try:
        proc = subprocess.run(
            cmd,
            input=user_prompt,
            capture_output=True,
            text=True,
            timeout=CLAUDE_TIMEOUT_SECONDS,
            check=False,
        )
    except subprocess.TimeoutExpired:
        raise RuntimeError(f"claude вызов превысил таймаут {CLAUDE_TIMEOUT_SECONDS}s")
    if proc.returncode != 0:
        raise RuntimeError(
            f"claude exit={proc.returncode}\nstderr: {proc.stderr[-500:]}"
        )
    return proc.stdout.strip()


# ─── Team runner ──────────────────────────────────────────────────────────────

class TeamRunner(threading.Thread):
    def __init__(self, team_id: str, orchestrator: "Orchestrator"):
        super().__init__(name=team_id, daemon=True)
        self.team_id = team_id
        self.orch = orchestrator
        self.status_path = STATE_DIR / "teams" / team_id / "status.json"
        self.status_path.parent.mkdir(parents=True, exist_ok=True)
        self._idle_since = time.time()

    def _heartbeat(self, phase: str, topic: str = "", task_id: str = "") -> None:
        write_json_atomic(self.status_path, {
            "team_id": self.team_id,
            "phase": phase,
            "topic": topic,
            "task_id": task_id,
            "last_heartbeat": utcnow_iso(),
        })

    def _should_stop(self) -> bool:
        rt = read_json(RUNTIME_PATH, default={}) or {}
        return bool(rt.get("should_stop"))

    def run(self) -> None:
        while not self._should_stop():
            checkpoint = self.orch.claim_checkpoint()
            if checkpoint is not None:
                try:
                    self._resume_task(checkpoint)
                except Exception as e:
                    append_log(f"{self.team_id} resume error: {e}")
                continue

            topic = self.orch.next_topic()
            if topic is None:
                self._heartbeat("idle")
                if self._should_stop():
                    break
                time.sleep(2)
                continue
            try:
                self._do_task(topic)
            except Exception as e:
                append_log(f"{self.team_id} task error in topic={topic}: {e}")
                self._heartbeat("error")
                time.sleep(3)
        self._heartbeat("done")

    def _do_task(self, topic: str) -> None:
        self._heartbeat("planning", topic=topic)

        planner_input = self._build_planner_input(topic)
        task_md = ""
        cond_hash = ""
        for attempt in range(3):
            extra = "" if attempt == 0 else (
                "\n\n[Предыдущая задача оказалась дубликатом существующей. "
                "Придумай заметно отличающуюся.]")
            task_md = run_claude(
                self.orch.config["models"]["planner"],
                self.orch.planner_prompt,
                planner_input + extra,
            )
            cond_hash = sha256_short(normalize_for_hash(task_md))
            if not self.orch.corpus.has_hash(cond_hash):
                break
            self.orch.log(f"{self.team_id} planner duplicate (attempt {attempt+1}/3)")
        else:
            self.orch.log(f"{self.team_id} skipping topic {topic} — 3 duplicates in a row")
            return

        # 2. Allocate task path
        task_dir = self.orch.corpus.next_task_path(topic)
        (task_dir / "task.md").write_text(task_md, encoding="utf-8")
        title = self._extract_title(task_md)
        started_at = utcnow_iso()
        task_id = f"{topic}-{task_dir.name}"

        if self._should_stop():
            self._save_checkpoint(task_dir, topic, "before_executor", 0,
                                  task_md, "", "", title, cond_hash, started_at)
            return

        # 3. Executor + Reviewer loop
        solution_md = ""
        review_md = ""
        verdict = "discard"
        iterations = 0
        max_iter = self.orch.config.get("max_revise_iterations", 2)

        for iteration in range(max_iter + 1):
            iterations = iteration + 1
            self._heartbeat("executor", topic=topic, task_id=task_id)
            executor_input = self._build_executor_input(task_md, review_md, iteration)
            solution_md = run_claude(
                self.orch.config["models"]["executor"],
                self.orch.executor_prompt,
                executor_input,
            )
            # Persist this iteration's solution immediately — full Planner→Executor→Reviewer
            # dialogue is preserved across revisions.
            (task_dir / f"solution-v{iterations}.md").write_text(solution_md, encoding="utf-8")

            if self._should_stop():
                self._save_checkpoint(task_dir, topic, "after_executor", iteration,
                                      task_md, solution_md, review_md, title, cond_hash,
                                      started_at)
                return

            self._heartbeat("reviewer", topic=topic, task_id=task_id)
            reviewer_input = self._build_reviewer_input(task_md, solution_md)
            review_md = run_claude(
                self.orch.config["models"]["reviewer"],
                self.orch.reviewer_prompt,
                reviewer_input,
            )
            (task_dir / f"review-v{iterations}.md").write_text(review_md, encoding="utf-8")
            verdict = self._extract_verdict(review_md)

            if verdict in ("pass", "discard"):
                break
            # else verdict == "revise" — loop continues

        if verdict == "revise":
            verdict = "discard"  # too many revisions

        # 4. Finalize
        (task_dir / "solution.md").write_text(solution_md, encoding="utf-8")
        (task_dir / "review.md").write_text(review_md, encoding="utf-8")
        finished_at = utcnow_iso()
        meta = {
            "id": task_id,
            "topic": topic,
            "title": title,
            "condition_hash": cond_hash,
            "models": dict(self.orch.config["models"]),
            "verdict": verdict,
            "iterations": iterations,
            "started_at": started_at,
            "finished_at": finished_at,
            "team_id": self.team_id,
        }
        write_json_atomic(task_dir / "meta.json", meta)
        ckpt = task_dir / "checkpoint.json"
        if ckpt.exists():
            ckpt.unlink()
        self.orch.corpus.append_index({
            "id": task_id, "topic": topic, "title": title,
            "condition_hash": cond_hash, "verdict": verdict,
            "path": str(task_dir.relative_to(DATA_DIR)),
            "finished_at": finished_at,
        })
        self.orch.log(f"{self.team_id} done: {task_id} → {verdict}")

    def _resume_task(self, checkpoint_path: Path) -> None:
        ck = read_json(checkpoint_path, default={}) or {}
        task_dir = checkpoint_path.parent
        topic = ck.get("topic", task_dir.parent.name)
        task_md = ck.get("task_md", "")
        solution_md = ck.get("solution_md", "")
        review_md = ck.get("review_md", "")
        title = ck.get("title", "")
        cond_hash = ck.get("condition_hash", "")
        started_at = ck.get("started_at", utcnow_iso())
        iter_done = int(ck.get("iteration", 0))
        phase = ck.get("phase", "before_executor")
        task_id = ck.get("task_id", f"{topic}-{task_dir.name}")
        max_iter = self.orch.config.get("max_revise_iterations", 2)

        self.orch.log(f"{self.team_id} resuming {task_id} from phase={phase} iter={iter_done}")

        verdict = "discard"
        iterations = iter_done

        # Resume strategy: pick up from `phase`. If phase=="after_executor" — skip executor for first iter and go straight to reviewer.
        for iteration in range(iter_done, max_iter + 1):
            iterations = iteration + 1
            need_executor = not (phase == "after_executor" and iteration == iter_done)
            if need_executor:
                self._heartbeat("executor", topic=topic, task_id=task_id)
                solution_md = run_claude(
                    self.orch.config["models"]["executor"],
                    self.orch.executor_prompt,
                    self._build_executor_input(task_md, review_md, iteration),
                )
                (task_dir / f"solution-v{iterations}.md").write_text(solution_md, encoding="utf-8")
                if self._should_stop():
                    self._save_checkpoint(task_dir, topic, "after_executor", iteration,
                                          task_md, solution_md, review_md, title,
                                          cond_hash, started_at)
                    return

            self._heartbeat("reviewer", topic=topic, task_id=task_id)
            review_md = run_claude(
                self.orch.config["models"]["reviewer"],
                self.orch.reviewer_prompt,
                self._build_reviewer_input(task_md, solution_md),
            )
            (task_dir / f"review-v{iterations}.md").write_text(review_md, encoding="utf-8")
            verdict = self._extract_verdict(review_md)
            if verdict in ("pass", "discard"):
                break
            phase = "before_executor"

        if verdict == "revise":
            verdict = "discard"

        (task_dir / "solution.md").write_text(solution_md, encoding="utf-8")
        (task_dir / "review.md").write_text(review_md, encoding="utf-8")
        finished_at = utcnow_iso()
        write_json_atomic(task_dir / "meta.json", {
            "id": task_id, "topic": topic, "title": title,
            "condition_hash": cond_hash,
            "models": dict(self.orch.config["models"]),
            "verdict": verdict, "iterations": iterations,
            "started_at": started_at, "finished_at": finished_at,
            "team_id": self.team_id, "resumed": True,
        })
        ckpt = task_dir / "checkpoint.json"
        if ckpt.exists():
            ckpt.unlink()
        self.orch.corpus.append_index({
            "id": task_id, "topic": topic, "title": title,
            "condition_hash": cond_hash, "verdict": verdict,
            "path": str(task_dir.relative_to(DATA_DIR)),
            "finished_at": finished_at,
        })
        self.orch.log(f"{self.team_id} resumed→done: {task_id} → {verdict}")

    def _save_checkpoint(self, task_dir: Path, topic: str, phase: str, iteration: int,
                         task_md: str, solution_md: str, review_md: str,
                         title: str, cond_hash: str, started_at: str) -> None:
        write_json_atomic(task_dir / "checkpoint.json", {
            "task_id": f"{topic}-{task_dir.name}",
            "topic": topic, "phase": phase, "iteration": iteration,
            "task_md": task_md, "solution_md": solution_md, "review_md": review_md,
            "title": title, "condition_hash": cond_hash, "started_at": started_at,
            "checkpoint_at": utcnow_iso(),
        })
        self.orch.log(f"{self.team_id} checkpoint saved at phase={phase} iter={iteration}")

    def _build_planner_input(self, topic: str) -> str:
        recent = self.orch.corpus.recent_titles(topic, 50)
        title = TOPIC_TITLES.get(topic, topic)
        recent_block = "\n".join(f"- {r['title']} ({r['verdict']})" for r in recent) or "— нет —"
        return (
            f"Тема: **{title}** (slug: `{topic}`)\n\n"
            f"Последние 50 задач этой темы (не повторяйся):\n"
            f"{recent_block}\n\n"
            f"Придумай новую задачу в этой теме согласно правилам системного промпта."
        )

    def _build_executor_input(self, task_md: str, review_md: str, iteration: int) -> str:
        if iteration == 0 or not review_md:
            return f"Условие задачи:\n\n{task_md}\n\nРеши задачу согласно системному промпту."
        return (
            f"Условие задачи:\n\n{task_md}\n\n"
            f"Предыдущее решение получило вердикт `revise`. Фидбек:\n\n{review_md}\n\n"
            f"Переработай решение, учитывая замечания."
        )

    def _build_reviewer_input(self, task_md: str, solution_md: str) -> str:
        return (
            f"Условие задачи:\n\n{task_md}\n\n"
            f"Решение Executor-а:\n\n{solution_md}\n\n"
            f"Оцени решение строго по чек-листу из системного промпта. "
            f"Выдай вердикт `pass` / `revise` / `discard` в YAML-блоке."
        )

    @staticmethod
    def _extract_title(task_md: str) -> str:
        for line in task_md.splitlines():
            line = line.strip()
            if line.startswith("# "):
                return line[2:].strip()
        return task_md.strip().split("\n", 1)[0][:80]

    @staticmethod
    def _extract_verdict(review_md: str) -> str:
        m = re.search(r"^---\s*\n.*?verdict:\s*(\w+).*?\n---", review_md,
                       re.DOTALL | re.MULTILINE)
        if m:
            v = m.group(1).strip().lower()
            if v in ("pass", "revise", "discard"):
                return v
        # Fallback: look for verdict word in first 500 chars
        head = review_md[:500].lower()
        for v in ("pass", "discard", "revise"):
            if f"verdict: {v}" in head or f"вердикт: {v}" in head:
                return v
        return "revise"  # safe default — try one more iteration


# ─── Orchestrator ─────────────────────────────────────────────────────────────

class Orchestrator:
    def __init__(self, config: dict):
        self.config = config
        self.corpus = CorpusStore()
        self.usage = UsageTracker()
        self.planner_prompt = (PROMPTS_DIR / "planner.md").read_text(encoding="utf-8")
        self.executor_prompt = (PROMPTS_DIR / "executor.md").read_text(encoding="utf-8")
        self.reviewer_prompt = (PROMPTS_DIR / "reviewer.md").read_text(encoding="utf-8")
        self._topic_idx_lock = threading.Lock()
        self._topic_idx = 0
        self._stop_event = threading.Event()
        self._started_at = time.time()
        self._checkpoint_lock = threading.Lock()
        self._checkpoint_queue = self.corpus.open_checkpoints()
        self._claimed_checkpoints: set[str] = set()

    # Topic round-robin
    def next_topic(self) -> str | None:
        topics = self.config.get("topics") or []
        if not topics:
            return None
        with self._topic_idx_lock:
            t = topics[self._topic_idx % len(topics)]
            self._topic_idx += 1
            return t

    def claim_checkpoint(self) -> Path | None:
        with self._checkpoint_lock:
            for p in list(self._checkpoint_queue):
                key = str(p)
                if key in self._claimed_checkpoints or not p.exists():
                    self._checkpoint_queue.remove(p)
                    continue
                self._claimed_checkpoints.add(key)
                self._checkpoint_queue.remove(p)
                return p
        return None

    def log(self, line: str) -> None:
        append_log(line)

    def _write_runtime(self, **extra) -> None:
        write_json_atomic(RUNTIME_PATH, {
            "pid": os.getpid(),
            "started_at": self._started_at,
            "now": time.time(),
            "should_stop": self._stop_event.is_set(),
            **extra,
        })

    def _check_limits(self) -> tuple[bool, str]:
        elapsed = time.time() - self._started_at
        if elapsed >= self.config["duration_seconds"]:
            return True, f"таймер ({format_duration(elapsed)})"
        u = self.usage.get()
        if u is not None:
            if u["five_hour_pct"] >= self.config["session_limit_percent"]:
                return True, f"сессионный лимит {u['five_hour_pct']:.1f}% ≥ {self.config['session_limit_percent']}%"
            if u["weekly_pct"] >= self.config["weekly_limit_percent"]:
                return True, f"недельный лимит {u['weekly_pct']:.1f}% ≥ {self.config['weekly_limit_percent']}%"
        return False, ""

    def install_signals(self) -> None:
        def handler(signum, _frame):
            self.log(f"signal {signum} received, requesting graceful stop")
            self._stop_event.set()
        # SIGINT works on every platform; SIGTERM is unix-only as a soft signal
        signal.signal(signal.SIGINT, handler)
        if hasattr(signal, "SIGTERM") and sys.platform != "win32":
            signal.signal(signal.SIGTERM, handler)

    def run(self) -> None:
        ensure_dirs()
        # Clear any leftover stop flag from previous run
        if STOP_FLAG_PATH.exists():
            STOP_FLAG_PATH.unlink()
        PIDFILE_PATH.write_text(str(os.getpid()))
        self.install_signals()
        self._write_runtime(reason="starting")
        self.log(f"orchestrator start pid={os.getpid()} config={self.config}")

        teams = [TeamRunner(f"team-{i+1}", self) for i in range(self.config["team_count"])]
        for t in teams:
            t.start()

        try:
            while True:
                stop, reason = self._check_limits()
                # Cross-platform stop flag (works on Windows where SIGTERM is hard-kill)
                if STOP_FLAG_PATH.exists():
                    stop, reason = True, "stop.flag"
                u = self.usage.get() or {}
                self._write_runtime(
                    five_hour_pct=u.get("five_hour_pct"),
                    weekly_pct=u.get("weekly_pct"),
                    monthly_pct=u.get("monthly_pct"),
                    elapsed=time.time() - self._started_at,
                    duration_seconds=self.config["duration_seconds"],
                    reason="running",
                )
                if stop or self._stop_event.is_set():
                    self.log(f"stop reason: {reason or 'external signal'}")
                    self._stop_event.set()
                    self._write_runtime(reason=f"stopping: {reason or 'signal'}",
                                         should_stop=True)
                    break
                # liveliness
                if not any(t.is_alive() for t in teams):
                    self.log("all teams exited")
                    break
                time.sleep(5)

            # graceful drain
            self.log("draining teams (max 30 min)")
            drain_deadline = time.time() + 30 * 60
            for t in teams:
                remaining = max(1, drain_deadline - time.time())
                t.join(timeout=remaining)
                if t.is_alive():
                    self.log(f"{t.name} still alive after drain — leaving thread")
        finally:
            self._write_runtime(reason="exited", should_stop=True)
            for p in (PIDFILE_PATH, STOP_FLAG_PATH):
                try:
                    p.unlink()
                except FileNotFoundError:
                    pass
            self.log("orchestrator exit")


# ─── Wizard ───────────────────────────────────────────────────────────────────

def _ask(prompt: str, default: str = "", choices: list[str] | None = None) -> str:
    suffix = ""
    if choices:
        suffix = f" [{'/'.join(choices)}]"
    if default:
        suffix += f" (default: {default})"
    while True:
        try:
            answer = input(f"{prompt}{suffix}: ").strip()
        except EOFError:
            answer = ""
        if not answer:
            answer = default
        if choices and answer not in choices:
            print(f"  ⚠ выбери из {choices}")
            continue
        if not answer:
            print("  ⚠ пустой ответ, попробуй ещё раз")
            continue
        return answer


def wizard() -> dict:
    print("─" * 60)
    print("taskforge — настройка")
    print("─" * 60)
    cfg = json.loads(json.dumps(DEFAULT_CONFIG))  # deep copy

    cfg["models"]["planner"] = _ask("Модель Planner-а", default="opus",
                                       choices=list(VALID_MODELS))
    cfg["models"]["executor"] = _ask("Модель Executor-а", default="sonnet",
                                        choices=list(VALID_MODELS))
    cfg["models"]["reviewer"] = _ask("Модель Reviewer-а", default="opus",
                                        choices=list(VALID_MODELS))
    while True:
        n = _ask("Сколько команд параллельно (оптимально 3)", default="3")
        try:
            cfg["team_count"] = int(n)
            if cfg["team_count"] >= 1:
                break
        except ValueError:
            pass
        print("  ⚠ нужно целое >= 1")
    while True:
        try:
            cfg["duration_seconds"] = parse_duration(
                _ask("Длительность (например 5h, 30m)", default="5h"))
            break
        except ValueError as e:
            print(f"  ⚠ {e}")
    while True:
        s = _ask("Сессионный лимит, % абсолют", default="50")
        try:
            cfg["session_limit_percent"] = float(s)
            if 0 < cfg["session_limit_percent"] <= 100:
                break
        except ValueError:
            pass
        print("  ⚠ число в (0, 100]")
    while True:
        s = _ask("Недельный лимит, % абсолют", default="50")
        try:
            cfg["weekly_limit_percent"] = float(s)
            if 0 < cfg["weekly_limit_percent"] <= 100:
                break
        except ValueError:
            pass
        print("  ⚠ число в (0, 100]")

    print("\nТемы (через запятую slug'и; пусто — все):")
    for slug, title in TOPICS:
        print(f"  {slug:16s} — {title}")
    raw = _ask("\nТемы", default="ALL")
    if raw.upper() == "ALL":
        cfg["topics"] = [s for s, _ in TOPICS]
    else:
        chosen = [s.strip() for s in raw.split(",") if s.strip()]
        valid = {s for s, _ in TOPICS}
        cfg["topics"] = [s for s in chosen if s in valid]
        if not cfg["topics"]:
            cfg["topics"] = [s for s, _ in TOPICS]

    print("\nИтого:")
    print(json.dumps(cfg, ensure_ascii=False, indent=2))
    confirm = _ask("Запустить сейчас? [y/n]", default="y", choices=["y", "n"])
    if confirm == "n":
        print("Отмена. Конфиг не сохранён.")
        sys.exit(0)
    save_config(cfg)
    return cfg


def save_config(cfg: dict) -> None:
    ensure_dirs()
    cfg["started_at"] = utcnow_iso()
    write_json_atomic(CONFIG_PATH, cfg)


def load_config(path: Path | None = None) -> dict:
    p = path or CONFIG_PATH
    cfg = read_json(p)
    if cfg is None:
        raise SystemExit(f"Конфиг не найден: {p}. Запусти `taskforge wizard`.")
    errs = validate_config(cfg)
    if errs:
        raise SystemExit("Невалидный конфиг:\n  - " + "\n  - ".join(errs))
    return cfg


# ─── CLI commands ─────────────────────────────────────────────────────────────

def cmd_wizard(_args) -> int:
    cfg = wizard()
    return _start(cfg)


def cmd_start(args) -> int:
    cfg = load_config(Path(args.config) if args.config else None)
    return _start(cfg)


def _start(cfg: dict) -> int:
    if PIDFILE_PATH.exists():
        try:
            old_pid = int(PIDFILE_PATH.read_text().strip())
            os.kill(old_pid, 0)
            print(f"⚠ taskforge уже запущен (pid={old_pid}). Используй `stop` или `status`.")
            return 1
        except (OSError, ValueError):
            PIDFILE_PATH.unlink(missing_ok=True)
    Orchestrator(cfg).run()
    return 0


def cmd_status(_args) -> int:
    rt = read_json(RUNTIME_PATH, default={}) or {}
    cfg = read_json(CONFIG_PATH, default={}) or {}
    pid_alive = False
    if PIDFILE_PATH.exists():
        try:
            os.kill(int(PIDFILE_PATH.read_text().strip()), 0)
            pid_alive = True
        except OSError:
            pid_alive = False
    print("taskforge status")
    print(f"  pidfile alive : {pid_alive}")
    if rt:
        elapsed = rt.get("elapsed", 0)
        dur = rt.get("duration_seconds", cfg.get("duration_seconds", 0))
        print(f"  elapsed       : {format_duration(elapsed)} / {format_duration(dur)}")
        for k in ("five_hour_pct", "weekly_pct", "monthly_pct"):
            if rt.get(k) is not None:
                print(f"  {k:14s}: {rt[k]:.1f}%")
        print(f"  reason        : {rt.get('reason')}")
        print(f"  should_stop   : {rt.get('should_stop', False)}")
    teams_dir = STATE_DIR / "teams"
    if teams_dir.exists():
        for s in sorted(teams_dir.iterdir()):
            st = read_json(s / "status.json", default={}) or {}
            print(f"  {s.name:10s}: {st.get('phase'):12s} topic={st.get('topic','-'):14s} "
                  f"hb={st.get('last_heartbeat','-')}")
    idx = read_json(INDEX_PATH, default=[]) or []
    print(f"  corpus size   : {len(idx)} задач")
    return 0


def cmd_stop(_args) -> int:
    if not PIDFILE_PATH.exists():
        print("taskforge не запущен (no pidfile)")
        return 1
    # Always create cross-platform stop flag first
    ensure_dirs()
    STOP_FLAG_PATH.write_text(utcnow_iso(), encoding="utf-8")
    print(f"stop.flag создан в {STOP_FLAG_PATH}")
    # On unix-like, also send SIGTERM for faster reaction
    if sys.platform != "win32":
        try:
            pid = int(PIDFILE_PATH.read_text().strip())
            os.kill(pid, signal.SIGTERM)
            print(f"SIGTERM → {pid}")
        except (OSError, ValueError) as e:
            print(f"⚠ SIGTERM failed: {e} (но flag поставлен — оркестратор увидит его за <5 сек)")
    print("Graceful drain до 30 минут — текущие задачи дочитываются, потом чекпоинт.")
    return 0


def cmd_resume(args) -> int:
    cfg = load_config(Path(args.config) if args.config else None)
    open_ck = list(CORPUS_DIR.glob("*/*/checkpoint.json"))
    print(f"Найдено чекпоинтов: {len(open_ck)}")
    return _start(cfg)


# ─── Entrypoint ───────────────────────────────────────────────────────────────

def main() -> int:
    parser = argparse.ArgumentParser(
        prog="taskforge",
        description="N команд параллельно генерируют качественный корпус решённых задач.",
    )
    parser.add_argument("--version", action="version", version=f"taskforge {VERSION}")
    sub = parser.add_subparsers(dest="cmd", required=True)

    sw = sub.add_parser("wizard", help="interactive setup, потом старт")
    sw.set_defaults(func=cmd_wizard)

    ss = sub.add_parser("start", help="запуск из готового config.json")
    ss.add_argument("--config", help=f"путь к config.json (default: {CONFIG_PATH})")
    ss.set_defaults(func=cmd_start)

    sst = sub.add_parser("status", help="текущее состояние")
    sst.set_defaults(func=cmd_status)

    sp = sub.add_parser("stop", help="graceful shutdown")
    sp.set_defaults(func=cmd_stop)

    sr = sub.add_parser("resume", help="продолжить с чекпоинтов")
    sr.add_argument("--config", help=f"путь к config.json (default: {CONFIG_PATH})")
    sr.set_defaults(func=cmd_resume)

    args = parser.parse_args()
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
